data <- afmDetachPoint(data, width = 10, mul1 = 1, mul2 = 5)
plot(data, segment = "retract") + geom_vline(xintercept = data$DP$DP)
data <- afmDetachPoint(data, width = 5, mul1 = 1, mul2 = 5)
plot(data, segment = "retract") + geom_vline(xintercept = data$DP$DP)
data <- afmBaselineCorrection(data)
plot(data)
data <- afmZeroPointSlope(data)
plot(data)
plot(data) + geom_vline(xintercept = data$Slopes$Z0Point)
library(afmToolkit)
data <- afmReadVeeco("FrcExport_turkey_24.txt", path = "c:/Users/Rafael Benítez/Documents/", TimeCol = FALSE, ZColStr = "Height")
data <- afmContactPoint(data, width = 10, mul1 = 1, mul2 = 10)
data <- afmDetachPoint(data, width = 5, mul1 = 1, mul2 = 5)
data <- afmBaselineCorrection(data)
data <- afmZeroPointSlope(data)
plot(data) + geom_vline(xintercept = data$Slopes$Z0Point)
summary(data)
data <- afmYoungModulus(data)
