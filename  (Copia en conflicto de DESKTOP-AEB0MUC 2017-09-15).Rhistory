Dj <- 10;
J <- 5;
s0 <- .1;
scales <- s0*2^((0:(J*Dj))/Dj);
dt <- 1;
windowrad <- 1;
kk <- data[[1]]$data %>% filter(Segment == "retract")
signal = as.numeric(kk$Force)
wsc <- windowed_scalogram_int(signal=signal,scales=scales,
windowrad = windowrad,'morlet')
z <- z[wsc$tt_ini:wsc$tt_fin]
z <- kk$Z
z <- z[wsc$tt_ini:wsc$tt_fin]
sinv <- sqrt(1/scales)
Sinv <- matrix(rep(sinv, times = dim(wsc$wsc)[1]),
nrow = dim(wsc$wsc)[1],
byrow = TRUE)
energywscL1 <-  rowSums(Sinv*wsc$wsc);
energywscL2 <-  sqrt(rowSums((Sinv*wsc$wsc)^2))
plot(energywscL2, type = "l")
nptsL2 <- length(energywscL2)
threshold <- 3*max(energywscL2[floor(0.9*nptsL2):nptsL2])
pksTemp <- findpeaks(energywscL2,nups = 1,minpeakheight = threshold,
minpeakdistance = 1)
maxPeak <- which.max(pksTemp[,1])
pks <- pksTemp[maxPeak:dim(pksTemp)[1],2]
Zpks <- z[pks]
par(mfrow = c(2,1))
plot(z,signal[wsc$tt_ini:wsc$tt_fin],type = "l")
abline(v = Zpks, lty = 2, col = "red")
plot(z,energywscL2,type = "l")
abline(v = Zpks, lty = 2, col = "red")
